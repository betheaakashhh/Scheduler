// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  avatar        String?
  timezone      String   @default("Asia/Kolkata")
  emailReminders Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  schedules     Schedule[]
  streaks       Streak[]
  xpLogs        XPLog[]
  academicTimetables AcademicTimetable[]

  @@map("users")
}

// ─────────────────────────────────────────────
// SCHEDULE  (one per user, one per day-of-week template)
// ─────────────────────────────────────────────
model Schedule {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Default")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slots     Slot[]

  @@map("schedules")
}

// ─────────────────────────────────────────────
// SLOT  (one time-block inside a schedule)
// ─────────────────────────────────────────────
model Slot {
  id           String    @id @default(cuid())
  scheduleId   String
  title        String
  startTime    String    // "HH:MM" 24h
  endTime      String    // "HH:MM" 24h
  tag          SlotTag
  strict       Boolean   @default(false)
  autoComplete Boolean   @default(false)
  emailReminder Boolean  @default(false)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  schedule     Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  checklistItems ChecklistItem[]
  completions  SlotCompletion[]

  @@map("slots")
}

// ─────────────────────────────────────────────
// CHECKLIST ITEM  (template items per slot)
// ─────────────────────────────────────────────
model ChecklistItem {
  id       String  @id @default(cuid())
  slotId   String
  text     String
  sortOrder Int    @default(0)

  slot     Slot    @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

// ─────────────────────────────────────────────
// SLOT COMPLETION  (one per day per slot)
// ─────────────────────────────────────────────
model SlotCompletion {
  id          String   @id @default(cuid())
  slotId      String
  date        String   // "YYYY-MM-DD"
  completedAt DateTime @default(now())
  xpEarned    Int      @default(25)

  slot        Slot     @relation(fields: [slotId], references: [id], onDelete: Cascade)
  foodItems   FoodItem[]
  checklistChecks ChecklistCheck[]

  @@unique([slotId, date])
  @@map("slot_completions")
}

// ─────────────────────────────────────────────
// FOOD ITEM  (per meal completion)
// ─────────────────────────────────────────────
model FoodItem {
  id           String         @id @default(cuid())
  completionId String
  name         String
  createdAt    DateTime       @default(now())

  completion   SlotCompletion @relation(fields: [completionId], references: [id], onDelete: Cascade)

  @@map("food_items")
}

// ─────────────────────────────────────────────
// CHECKLIST CHECK  (per-day checklist state)
// ─────────────────────────────────────────────
model ChecklistCheck {
  id           String         @id @default(cuid())
  completionId String
  itemText     String
  checked      Boolean        @default(false)

  completion   SlotCompletion @relation(fields: [completionId], references: [id], onDelete: Cascade)

  @@map("checklist_checks")
}

// ─────────────────────────────────────────────
// STREAK
// ─────────────────────────────────────────────
model Streak {
  id            String   @id @default(cuid())
  userId        String   @unique
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveDate String?  // "YYYY-MM-DD"
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

// ─────────────────────────────────────────────
// XP LOG
// ─────────────────────────────────────────────
model XPLog {
  id        String   @id @default(cuid())
  userId    String
  points    Int
  reason    String
  date      String   // "YYYY-MM-DD"
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("xp_logs")
}

// ─────────────────────────────────────────────
// ACADEMIC TIMETABLE
// ─────────────────────────────────────────────
model AcademicTimetable {
  id        String   @id @default(cuid())
  userId    String
  name      String
  rawText   String   @db.Text
  periods   Json     // Array of { day, startTime, endTime, subject, teacher? }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("academic_timetables")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────
enum SlotTag {
  WAKE_UP
  MORNING_ROUTINE
  BREAKFAST
  LUNCH
  DINNER
  COLLEGE
  SELF_STUDY
  GYM
  WORKOUT
  WALK
  SLEEP
  WORK
  HYDRATION
  CUSTOM
}
